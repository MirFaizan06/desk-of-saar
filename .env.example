# ────────────────────────────────────────────────────────────────
# Firebase Configuration
# Get these from: Firebase Console → Project Settings → Your apps
# ────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ────────────────────────────────────────────────────────────────
# Amazon S3 Configuration
# Create a restricted IAM user — see S3_SETUP.md for exact policy
# ────────────────────────────────────────────────────────────────
VITE_AWS_REGION=ap-south-1
VITE_AWS_ACCESS_KEY_ID=your_iam_access_key_id
VITE_AWS_SECRET_ACCESS_KEY=your_iam_secret_access_key
VITE_S3_BUCKET=your-s3-bucket-name
VITE_S3_PUBLIC_URL=https://your-s3-bucket-name.s3.ap-south-1.amazonaws.com
